#SP Info:
SP_DOMAIN=localhost:3000
# IdP Info:
SAML_IDP_METADATA_URL=None
SAML_IDP_METADATA_VALIDATE_CERT=None
SAML_IDP_ENTITY_ID=None
SAML_IDP_SSO_URL=None
SAML_IDP_SLO_URL=None
SAML_IDP_CERT=None

# SP JWT 
HM_JWT_SECRET_KEY=secret
HM_JWT_ALGORITHM=HS256
HM_JWT_EXPIRATION_MINUTES=60
HM_JWT_REDIRECT_URL=/dashboard

# Set to Environment var to production to enable 
# secure_flag on JWT token transmission over https
ENVIRONMENT=development
